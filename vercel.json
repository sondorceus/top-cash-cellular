{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cleanup-photos",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/fedex-poll",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/inbox-watch",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/ai-daily-summary",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/watchdog",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/sequences",
      "schedule": "0 17 * * *"
    }
  ]
}
